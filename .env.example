NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only. Do not expose this through NEXT_PUBLIC_ variables.
# Not required for the current implementation unless a future server-only admin workflow needs it.
SUPABASE_SERVICE_ROLE_KEY=

# Server-side Clio Grow integration for completed intake submissions.
# Set either CLIO_GROW_INBOX_LEADS_URL directly, or set CLIO_GROW_API_BASE_URL
# and the app will post to /inbox_leads.
CLIO_GROW_API_TOKEN=
CLIO_GROW_API_BASE_URL=
CLIO_GROW_INBOX_LEADS_URL=
NEXT_PUBLIC_SITE_URL=
